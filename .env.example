# Copy to .env and fill in. Never commit .env itself — only this example.
# Every value comes from the Supabase dashboard.

# --- Database -----------------------------------------------------------------
# Project Settings → Database → Connection string

# Pooled connection (PgBouncer, port 6543). Used by the app at runtime.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct, unpooled connection (port 5432). Migrations and the seed require it:
# PgBouncer in transaction mode cannot run the statements a migration needs.
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres"

# --- Supabase -----------------------------------------------------------------
# Project Settings → API

# Project URL. Public by design — the browser needs it to build image URLs.
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"

# Publishable (anon) key. Public by design; Row Level Security is what protects
# the data behind it.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="<publishable-key>"

# SECRET. Bypasses Row Level Security entirely — full read/write on the database.
# Server-side only: the seed and the storage service.
#
# Never prefix this with NEXT_PUBLIC_. Next.js inlines every NEXT_PUBLIC_* value
# into the JavaScript bundle it sends to the browser, so a NEXT_PUBLIC_ service
# role key would hand every visitor full access to the database.
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"

# --- API ----------------------------------------------------------------------

# Shared secret for the write endpoints (POST /api/upload). Any random string of
# 16+ characters: `openssl rand -hex 24`.
#
# Optional, and deliberately fail-closed. Unset, uploads work in development and
# are REFUSED in production — an unset secret must never mean "allow everyone".
# Set it before deploying. A stopgap until real auth exists.
ADMIN_API_KEY="<random-32-char-secret>"

# --- Analytics (optional) -----------------------------------------------------
# All optional and inert until set. When a value is present, its tag loads via
# src/components/analytics/Analytics.tsx and src/lib/analytics.ts forwards
# events. Public by design (injected into the browser), so NEXT_PUBLIC_ is
# correct here — these are measurement IDs, not secrets. Leave unset for now.

# Google Analytics 4 measurement ID, e.g. G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=""

# Google Tag Manager container ID, e.g. GTM-XXXXXXX
NEXT_PUBLIC_GTM_ID=""

# Microsoft Clarity project ID
NEXT_PUBLIC_CLARITY_ID=""

# --- Admin auth (BetterAuth) — Phase 13.1 -------------------------------------
# The internal admin CMS. Sessions are HTTP-only cookies signed with this
# secret; keep it secret and stable (rotating it invalidates all sessions).

# Random 32-byte secret: `openssl rand -hex 32`
BETTER_AUTH_SECRET="<random-hex-secret>"
# The app's own origin. http://localhost:3000 in dev; the deployed URL in prod.
BETTER_AUTH_URL="http://localhost:3000"

# Credentials for the seeded SUPER_ADMIN (npm run seed:admin). The seed is
# idempotent and non-destructive. Change the password before real deployment.
ADMIN_EMAIL="admin@stayze.in"
ADMIN_PASSWORD="<at-least-8-characters>"
ADMIN_NAME="Stayze Admin"
