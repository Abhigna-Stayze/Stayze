# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files. .env.example is the one exception — it holds placeholders only.
.env*
!.env.example

# spec documents live in the parent workspace, not in this repo
*.docx
*.pdf
*.pptx

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma client is generated, not committed — run `npx prisma generate`
/src/generated/prisma

# agent skills — kept local, restore with `npx skills add supabase/agent-skills`
/.agents
/.claude
/skills-lock.json
